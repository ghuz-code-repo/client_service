# .env - Environment variables for Client Service
# Copy this file to .env: cp .env.example .env
# WARNING: This file must NOT be committed to version control (Git)

# --- Flask Settings ---
SECRET_KEY='CHANGE_ME_GENERATE_RANDOM_HEX'
FLASK_APP=run.py
FLASK_DEBUG=True

# --- Mail Server Settings ---
MAIL_PORT=587
MAIL_USE_TLS=true

# --- DEV MAIL ---
MAIL_SERVER=mail.example.com
MAIL_USERNAME=robot@example.com
MAIL_PASSWORD='CHANGE_ME'
MAIL_DEFAULT_SENDER=robot@example.com

# --- PROD MAIL ---
# MAIL_SERVER=172.16.x.x
# MAIL_USERNAME=clientservice@example.com
# MAIL_PASSWORD='CHANGE_ME'
# MAIL_DEFAULT_SENDER=clientservice@example.com

# --- Remote MySQL Database ---
SOURCE_MYSQL_HOST=CHANGE_ME
SOURCE_MYSQL_USER=CHANGE_ME
SOURCE_MYSQL_PASSWORD='CHANGE_ME'
SOURCE_MYSQL_PORT=9906
SOURCE_MYSQL_DATABASE=CHANGE_ME

# --- Default admin account ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD='CHANGE_ME'

# --- Auth Service (centralized authorization) ---
AUTH_SERVICE_URL=http://auth-service:80
# NOTE: Must be identical to JWT_SECRET in auth-service and referal!
JWT_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_base64_48"
# NOTE: Must be identical to INTERNAL_API_KEY in auth-service!
INTERNAL_API_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
